<Application x:Class="WindowsNotch.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <LinearGradientBrush x:Key="NotchBackgroundBrush"
                             StartPoint="0,0"
                             EndPoint="0,1">
            <GradientStop Color="#F61C1C20"
                          Offset="0" />
            <GradientStop Color="#F60F0F12"
                          Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="NotchBorderBrush" Color="#30FFFFFF" />
        <SolidColorBrush x:Key="PanelBrush" Color="#14161A" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#20FFFFFF" />
        <SolidColorBrush x:Key="PanelInnerBrush" Color="#0DFFFFFF" />
        <SolidColorBrush x:Key="PanelInnerBorderBrush" Color="#18FFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#7CB8FF" />
        <SolidColorBrush x:Key="AccentFillBrush" Color="#305A9CFF" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#E8F5F5F7" />
        <SolidColorBrush x:Key="MutedBrush" Color="#8AF5F5F7" />
    </Application.Resources>
</Application>

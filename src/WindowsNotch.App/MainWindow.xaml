<Window x:Class="WindowsNotch.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowsNotch"
        Width="220"
        Height="52"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="False"
        AllowDrop="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragOver"
        DragLeave="Window_DragLeave">
    <Grid Margin="6,0,6,10">
        <Border x:Name="NotchBody"
                Background="{StaticResource NotchBackgroundBrush}"
                BorderBrush="{StaticResource NotchBorderBrush}"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,24,24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Button x:Name="SettingsButton"
                            Width="22"
                            Height="22"
                            Margin="0,4,10,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Padding="0"
                            Cursor="Hand"
                            Focusable="False"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Visibility="Collapsed"
                            Click="SettingsButton_Click">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                    FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="&#xE713;" />
                    </Button>
                </Grid>

                <Border x:Name="ExpandedContentViewport"
                        Grid.Row="1"
                        Margin="12,2,12,12"
                        Height="0"
                        Opacity="1"
                        Background="Transparent"
                        ClipToBounds="True">
                    <Grid x:Name="ExpandedContentRoot">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="198" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="SharePanel"
                                Grid.Column="0"
                                Padding="10"
                                CornerRadius="18"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                AllowDrop="True"
                                DragEnter="SharePanel_DragEnter"
                                DragOver="SharePanel_DragOver"
                                DragLeave="SharePanel_DragLeave"
                                Drop="SharePanel_Drop">
                            <Grid>
                                <Border x:Name="ShareDropZone"
                                        MinHeight="96"
                                        Padding="12"
                                        CornerRadius="16"
                                        Background="{StaticResource PanelInnerBrush}"
                                        BorderBrush="{StaticResource PanelInnerBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel VerticalAlignment="Center">
                                        <Grid Width="38"
                                              Height="38"
                                              HorizontalAlignment="Center">
                                            <Ellipse Stroke="{StaticResource AccentBrush}"
                                                     StrokeThickness="1.5"
                                                     Opacity="0.9" />
                                            <Ellipse Width="16"
                                                     Height="16"
                                                     Margin="10,10,0,0"
                                                     HorizontalAlignment="Left"
                                                     VerticalAlignment="Top"
                                                     Stroke="{StaticResource AccentBrush}"
                                                     StrokeThickness="1.5"
                                                     Opacity="0.82" />
                                            <Ellipse Width="6"
                                                     Height="6"
                                                     Margin="23,8,0,0"
                                                     HorizontalAlignment="Left"
                                                     VerticalAlignment="Top"
                                                     Fill="{StaticResource AccentBrush}" />
                                        </Grid>

                                        <TextBlock Margin="0,8,0,0"
                                                   HorizontalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource SubtleBrush}"
                                                   Text="AirDrop" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border x:Name="ShelfPanel"
                                Grid.Column="2"
                                Padding="10"
                                CornerRadius="18"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                AllowDrop="True"
                                DragEnter="ShelfPanel_DragEnter"
                                DragOver="ShelfPanel_DragOver"
                                DragLeave="ShelfPanel_DragLeave"
                                Drop="ShelfPanel_Drop">
                            <Grid>
                                <Grid Height="106"
                                      ClipToBounds="True">
                                    <Border x:Name="EmptyShelfPanel"
                                            Height="106"
                                            Padding="16"
                                            CornerRadius="16"
                                            Background="{StaticResource PanelInnerBrush}"
                                            BorderBrush="{StaticResource PanelInnerBorderBrush}"
                                            BorderThickness="1"
                                            VerticalAlignment="Top">
                                        <StackPanel VerticalAlignment="Center">
                                            <Grid Width="38"
                                                  Height="38"
                                                  HorizontalAlignment="Center">
                                                <Border Margin="6,10,6,7"
                                                        CornerRadius="6"
                                                        BorderBrush="{StaticResource AccentBrush}"
                                                        BorderThickness="1.5" />
                                                <Path Margin="11,4,11,20"
                                                      Stroke="{StaticResource AccentBrush}"
                                                      StrokeThickness="1.5"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      Data="M 0 10 L 9 1 L 18 10" />
                                                <Line X1="19"
                                                      Y1="5"
                                                      X2="19"
                                                      Y2="22"
                                                      Stroke="{StaticResource AccentBrush}"
                                                      StrokeThickness="1.5"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" />
                                            </Grid>
                                            <TextBlock Margin="0,8,0,0"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SubtleBrush}"
                                                       Text="Drop files here" />
                                        </StackPanel>
                                    </Border>

                                    <ListBox x:Name="ShelfList"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Height="106"
                                             VerticalAlignment="Top"
                                             Visibility="Collapsed"
                                             FocusVisualStyle="{x:Null}"
                                             SelectionChanged="ShelfList_SelectionChanged"
                                             PreviewKeyDown="ShelfList_PreviewKeyDown"
                                             ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                             ScrollViewer.CanContentScroll="False"
                                             PreviewMouseLeftButtonDown="ShelfList_PreviewMouseLeftButtonDown"
                                             PreviewMouseMove="ShelfList_PreviewMouseMove">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>

                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding"
                                                        Value="0" />
                                                <Setter Property="Margin"
                                                        Value="0,0,8,0" />
                                                <Setter Property="Background"
                                                        Value="Transparent" />
                                                <Setter Property="BorderThickness"
                                                        Value="0" />
                                                <Setter Property="HorizontalContentAlignment"
                                                        Value="Stretch" />
                                                <Setter Property="VerticalContentAlignment"
                                                        Value="Stretch" />
                                                <Setter Property="FocusVisualStyle"
                                                        Value="{x:Null}" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="ItemChrome"
                                                                    Padding="0"
                                                                    Background="Transparent"
                                                                    CornerRadius="12">
                                                                <ContentPresenter />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected"
                                                                         Value="True">
                                                                    <Setter TargetName="ItemChrome"
                                                                            Property="Background"
                                                                            Value="#14D1FF" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>

                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="110"
                                                        Height="106"
                                                        Padding="8"
                                                        CornerRadius="14"
                                                        Background="{StaticResource PanelInnerBrush}"
                                                        BorderBrush="{StaticResource PanelInnerBorderBrush}"
                                                        BorderThickness="1">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="62" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>

                                                        <Border Grid.Row="0"
                                                                CornerRadius="10"
                                                                Background="#14FFFFFF"
                                                                ClipToBounds="True">
                                                            <Grid>
                                                                <Image x:Name="ThumbnailImage"
                                                                       Stretch="UniformToFill"
                                                                       Source="{Binding ThumbnailSource}">
                                                                    <Image.Style>
                                                                        <Style TargetType="Image">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding ThumbnailSource}"
                                                                                             Value="{x:Null}">
                                                                                    <Setter Property="Visibility"
                                                                                            Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Image.Style>
                                                                </Image>
                                                                <Border x:Name="FallbackBadge"
                                                                        Background="#14FFFFFF"
                                                                        Visibility="Collapsed">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding ThumbnailSource}"
                                                                                             Value="{x:Null}">
                                                                                    <Setter Property="Visibility"
                                                                                            Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <StackPanel VerticalAlignment="Center">
                                                                        <TextBlock HorizontalAlignment="Center"
                                                                                   FontSize="10"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource AccentBrush}"
                                                                                   Text="{Binding KindLabel}" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </Grid>
                                                        </Border>

                                                        <TextBlock Grid.Row="1"
                                                                   Margin="0,8,0,0"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Top"
                                                                   TextAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="Wrap"
                                                                   MaxHeight="26"
                                                                   FontSize="10.5"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource SubtleBrush}"
                                                                   Text="{Binding DisplayName}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Popup x:Name="DragPreviewPopup"
               AllowsTransparency="True"
               Focusable="False"
               IsHitTestVisible="False"
               Placement="AbsolutePoint"
               PopupAnimation="None"
               StaysOpen="True">
            <Border Padding="8"
                    CornerRadius="14"
                    Background="#F018181C"
                    BorderBrush="#26FFFFFF"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="22"
                                      ShadowDepth="0"
                                      Color="#D0000000"
                                      Opacity="0.46" />
                </Border.Effect>
                <Grid Width="120">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="74" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            CornerRadius="10"
                            Background="#18FFFFFF"
                            ClipToBounds="True">
                        <Grid>
                            <Image x:Name="DragPreviewImage"
                                   Stretch="UniformToFill"
                                   Visibility="Collapsed" />
                            <Border x:Name="DragPreviewFallbackBadge"
                                    Background="#18FFFFFF"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="DragPreviewKindText"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}" />
                            </Border>
                        </Grid>
                    </Border>

                    <TextBlock x:Name="DragPreviewNameText"
                               Grid.Row="1"
                               Margin="0,8,0,0"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="30"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SubtleBrush}" />
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Window>

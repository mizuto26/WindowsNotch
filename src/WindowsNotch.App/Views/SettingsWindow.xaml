<Window x:Class="WindowsNotch.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="420"
        MinHeight="304"
        ResizeMode="NoResize"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        SizeChanged="Window_SizeChanged"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border x:Name="WindowSurfaceBorder"
            Margin="0"
            Padding="0"
            Background="{StaticResource NotchBackgroundBrush}"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="16,14,16,12"
                    BorderBrush="#14FFFFFF"
                    BorderThickness="0,0,0,1"
                    Background="#08FFFFFF">
                <Grid>
                    <Button HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource TrafficLightButtonStyle}"
                            Margin="0"
                            Background="#FFFE5F57"
                            Click="CloseChromeButton_Click" />

                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SubtleBrush}"
                               Text="WindowsNotch" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="16,16,16,0"
                    Padding="16"
                    CornerRadius="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SubtleBrush}"
                                   Text="Launch at startup" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="Open the notch automatically when Windows starts." />
                    </StackPanel>

                    <CheckBox x:Name="LaunchAtStartupCheckBox"
                              Grid.Column="1"
                              VerticalAlignment="Center"
                              Style="{StaticResource ToggleSwitchStyle}" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="16,12,16,0"
                    Padding="16"
                    CornerRadius="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SubtleBrush}"
                               Text="Sharing" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{StaticResource MutedBrush}"
                               Text="Open the iCloud folder used for instant sharing." />
                    <StackPanel Margin="0,14,0,0"
                                Orientation="Horizontal">
                        <Button HorizontalAlignment="Left"
                                Style="{StaticResource RoundedActionButtonStyle}"
                                Click="OpenShareGuideButton_Click"
                                Content="How to send to iPhone" />
                        <Button Margin="10,0,0,0"
                                HorizontalAlignment="Left"
                                Style="{StaticResource RoundedActionButtonStyle}"
                                Click="OpenICloudFolderButton_Click"
                                Content="Open iCloud share folder" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid Grid.Row="3"
                  Margin="16,16,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        MinWidth="90"
                        Margin="0,0,8,0"
                        Style="{StaticResource RoundedActionButtonStyle}"
                        Click="ExitButton_Click"
                        Content="Quit app" />

                <Button Grid.Column="2"
                        MinWidth="90"
                        Style="{StaticResource PrimaryRoundedActionButtonStyle}"
                        Click="SaveButton_Click"
                        Content="Save" />
            </Grid>
        </Grid>
    </Border>
</Window>

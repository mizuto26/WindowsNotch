<Window x:Class="WindowsNotch.App.ShareGuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="How to send to iPhone"
        Icon="/Assets/app.ico"
        Width="448"
        MinHeight="0"
        ResizeMode="NoResize"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        SizeChanged="Window_SizeChanged"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border x:Name="WindowSurfaceBorder"
            Margin="12"
            Background="{StaticResource NotchBackgroundBrush}"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="20">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="18,14,18,12"
                    BorderBrush="#14FFFFFF"
                    BorderThickness="0,0,0,1"
                    Background="#08FFFFFF">
                <Grid>
                    <Button
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="0"
                            Background="#FFFE5F57"
                            Style="{StaticResource TrafficLightButtonStyle}"
                            Click="CloseButton_Click">
                    </Button>

                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SubtleBrush}"
                               Text="Send to iPhone" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="1"
                        Margin="18,18,18,0">
                <Border Padding="18"
                        CornerRadius="18"
                        Background="#0AFFFFFF"
                        BorderBrush="#14FFFFFF"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SubtleBrush}"
                                   Text="iCloud Drive Setup" />
                        <TextBlock Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="12.5"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="Use the same Apple Account on Windows and iPhone, then drop a file into the iCloud Drive area." />
                    </StackPanel>
                </Border>

                <Border Margin="0,14,0,0"
                        Padding="16"
                        CornerRadius="18"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource GuideStepBadgeStyle}">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SubtleBrush}"
                                           Text="1" />
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Margin="10,1,0,0"
                                       FontSize="12.5"
                                       Foreground="{StaticResource SubtleBrush}"
                                       Text="Install iCloud for Windows and turn on iCloud Drive." />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource GuideStepBadgeStyle}">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SubtleBrush}"
                                           Text="2" />
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Margin="10,1,0,0"
                                       FontSize="12.5"
                                       Foreground="{StaticResource SubtleBrush}"
                                       Text="Sign in on Windows and iPhone with the same Apple Account." />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource GuideStepBadgeStyle}">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SubtleBrush}"
                                           Text="3" />
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Margin="10,1,0,0"
                                       FontSize="12.5"
                                       Foreground="{StaticResource SubtleBrush}"
                                       Text="Drop a file on the iCloud Drive side of the notch." />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource GuideStepBadgeStyle}">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SubtleBrush}"
                                           Text="4" />
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Margin="10,1,0,0"
                                       FontSize="12.5"
                                       Foreground="{StaticResource SubtleBrush}"
                                       Text="Open Files on iPhone and look in iCloud Drive > WindowsNotch." />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Margin="0,14,0,0"
                        Padding="14"
                        CornerRadius="16"
                        Background="{StaticResource PanelInnerBrush}"
                        BorderBrush="{StaticResource PanelInnerBorderBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="FolderPathTextBlock"
                               FontSize="11.5"
                               Foreground="{StaticResource SubtleBrush}"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <Grid Grid.Row="2"
                  Margin="18,18,18,22">
                <Button HorizontalAlignment="Right"
                        Style="{StaticResource PrimaryCompactActionButtonStyle}"
                        Click="OkButton_Click"
                        Content="OK" />
            </Grid>
        </Grid>
    </Border>
</Window>

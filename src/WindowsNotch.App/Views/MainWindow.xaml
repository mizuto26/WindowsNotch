<Window x:Class="WindowsNotch.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowsNotch" Width="220" Height="52" WindowStartupLocation="Manual"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False" Topmost="False" AllowDrop="True"
        UseLayoutRounding="True" SnapsToDevicePixels="True" Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown" DragEnter="Window_DragEnter"
        DragOver="Window_DragOver" DragLeave="Window_DragLeave">
    <Grid Margin="6,0,6,10">
        <Border x:Name="NotchBody" Background="{StaticResource NotchBackgroundBrush}" BorderBrush="{StaticResource NotchBorderBrush}" BorderThickness="1,0,1,1" CornerRadius="0" RenderTransformOrigin="0.5,0" SizeChanged="NotchBody_SizeChanged">
            <Border.RenderTransform><ScaleTransform x:Name="NotchScaleTransform" ScaleX="1" ScaleY="1" /></Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="34" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <StackPanel x:Name="ModeSwitchPanel" Margin="26,4,0,0" HorizontalAlignment="Left" Orientation="Horizontal" Visibility="Collapsed">
                        <Button x:Name="MusicModeButton" Margin="0,0,14,0" Click="MusicModeButton_Click" Style="{StaticResource NotchTopIconButtonStyle}"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#F3F5F7" Text="&#xE189;" /></Button>
                        <Button x:Name="FilesModeButton" Click="FilesModeButton_Click" Style="{StaticResource NotchTopIconButtonStyle}"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#F3F5F7" Text="&#xE91B;" /></Button>
                    </StackPanel>
                    <Button x:Name="SettingsButton" Margin="0,4,26,0" HorizontalAlignment="Right" VerticalAlignment="Top" Visibility="Collapsed" Click="SettingsButton_Click" Style="{StaticResource NotchTopIconButtonStyle}"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#F3F5F7" Text="&#xE713;" /></Button>
                </Grid>
                <Grid Grid.Row="1" Margin="12,0,12,12">
                    <Border x:Name="ExpandedContentViewport" Margin="0,2,0,0" Height="0" Opacity="0" Background="Transparent" ClipToBounds="True">
                    <Grid x:Name="ExpandedContentRoot" RenderTransformOrigin="0.5,0">
                        <Grid.RenderTransform><TransformGroup><ScaleTransform x:Name="ExpandedContentScaleTransform" ScaleX="0.97" ScaleY="0.9" /><TranslateTransform x:Name="ExpandedContentTranslateTransform" Y="-6" /></TransformGroup></Grid.RenderTransform>
                        <Border x:Name="FilesView" Height="162" Padding="12,14,12,12" CornerRadius="20" Background="{StaticResource NotchBackgroundBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="132" /><ColumnDefinition Width="18" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border x:Name="SharePanel" Grid.Column="0" Height="132" Padding="0" CornerRadius="18" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" VerticalAlignment="Top" AllowDrop="True" DragEnter="SharePanel_DragEnter" DragOver="SharePanel_DragOver" DragLeave="SharePanel_DragLeave" Drop="SharePanel_Drop">
                                    <Grid>
                                        <Rectangle RadiusX="18" RadiusY="18" Stroke="#22FFFFFF" StrokeThickness="1.2" StrokeDashArray="5 5" Fill="#FF000000" SnapsToDevicePixels="True" />
                                        <Border x:Name="ShareDropZone" Margin="4" CornerRadius="16" Background="#FF000000" BorderBrush="Transparent" BorderThickness="0" AllowDrop="True" DragEnter="SharePanel_DragEnter" DragOver="SharePanel_DragOver" DragLeave="SharePanel_DragLeave" Drop="SharePanel_Drop">
                                            <StackPanel VerticalAlignment="Center">
                                                <Border x:Name="ShareStatusBadge" Width="48" Height="48" HorizontalAlignment="Center" Background="#12FFFFFF" CornerRadius="24">
                                                    <Grid>
                                                        <Viewbox Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform">
                                                            <Canvas Width="24" Height="24">
                                                                <Path x:Name="ShareCloudIcon" Fill="{StaticResource SubtleBrush}" Data="M17.8,10.6 C17.2,7.7 14.6,5.6 11.5,5.6 C9,5.6 6.8,7 5.8,9.2 C3.1,9.4 1,11.8 1,14.7 C1,17.8 3.5,20.3 6.6,20.3 L17.6,20.3 C20.5,20.3 22.9,17.9 22.9,15 C22.9,12.3 20.8,10.1 18.1,9.9 z M12.4,10.1 L12.4,15.2 L14.3,13.4 L15.5,14.6 L11.5,18.5 L7.5,14.6 L8.7,13.4 L10.6,15.2 L10.6,10.1 z" />
                                                            </Canvas>
                                                        </Viewbox>
                                                        <TextBlock x:Name="ShareSuccessIcon" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#FF163300" Text="&#xE73E;" Visibility="Collapsed" />
                                                    </Grid>
                                                </Border>
                                                <TextBlock x:Name="ShareStatusText" Margin="0,12,0,0" HorizontalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SubtleBrush}" Text="iCloud Drive" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                                <Border x:Name="ShelfPanel" Grid.Column="2" Height="132" Padding="0" CornerRadius="18" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" VerticalAlignment="Top" AllowDrop="True" DragEnter="ShelfPanel_DragEnter" DragOver="ShelfPanel_DragOver" DragLeave="ShelfPanel_DragLeave" Drop="ShelfPanel_Drop">
                                    <Grid ClipToBounds="True">
                                        <Rectangle RadiusX="18" RadiusY="18" Stroke="#22FFFFFF" StrokeThickness="1.2" StrokeDashArray="5 5" Fill="#FF000000" SnapsToDevicePixels="True" />
                                        <Border x:Name="EmptyShelfPanel" Margin="4" CornerRadius="16" Background="#FF000000" BorderBrush="Transparent" BorderThickness="0" AllowDrop="True" DragEnter="ShelfPanel_DragEnter" DragOver="ShelfPanel_DragOver" DragLeave="ShelfPanel_DragLeave" Drop="ShelfPanel_Drop">
                                            <StackPanel VerticalAlignment="Center">
                                                <Border Width="48" Height="48" HorizontalAlignment="Center" Background="#12FFFFFF" CornerRadius="24">
                                                    <Viewbox Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform"><Canvas Width="22" Height="22"><Path Stroke="{StaticResource SubtleBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M11 4.5 L11 13.4 M7.2 9.8 L11 6 L14.8 9.8" /><Path Stroke="{StaticResource SubtleBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M5.5 15.4 L5.5 16.6 C5.5 18 6.6 19.1 8 19.1 L14 19.1 C15.4 19.1 16.5 18 16.5 16.6 L16.5 15.4" /></Canvas></Viewbox>
                                                </Border>
                                                <TextBlock Margin="0,12,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SubtleBrush}" Text="Drop files here" />
                                            </StackPanel>
                                        </Border>
                                        <ListBox x:Name="ShelfList" Margin="8,4,8,4" Background="Transparent" BorderThickness="0" Height="124" VerticalAlignment="Center" Visibility="Collapsed" FocusVisualStyle="{x:Null}" SelectionChanged="ShelfList_SelectionChanged" PreviewKeyDown="ShelfList_PreviewKeyDown" ScrollViewer.HorizontalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="False" PreviewMouseLeftButtonDown="ShelfList_PreviewMouseLeftButtonDown" PreviewMouseMove="ShelfList_PreviewMouseMove" AllowDrop="True" DragEnter="ShelfPanel_DragEnter" DragOver="ShelfPanel_DragOver" DragLeave="ShelfPanel_DragLeave" Drop="ShelfPanel_Drop">
                                            <ListBox.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="Padding" Value="0" /><Setter Property="Margin" Value="0,0,10,0" /><Setter Property="Background" Value="Transparent" /><Setter Property="BorderThickness" Value="0" /><Setter Property="HorizontalContentAlignment" Value="Stretch" /><Setter Property="VerticalContentAlignment" Value="Stretch" /><Setter Property="FocusVisualStyle" Value="{x:Null}" /><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><Border x:Name="ItemChrome" Padding="0" Background="Transparent" CornerRadius="14"><ContentPresenter /></Border><ControlTemplate.Triggers><Trigger Property="IsSelected" Value="True"><Setter TargetName="ItemChrome" Property="Background" Value="#183F8CFF" /></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style></ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                    <Border x:Name="ShelfItemCard" Width="96" Height="116" Padding="6" CornerRadius="16" Background="#090909" BorderBrush="#2D6EDBFF" BorderThickness="1">
                                                        <Grid>
                                                            <Grid.RowDefinitions><RowDefinition Height="76" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                                            <Border Grid.Row="0" CornerRadius="14" Background="#14FFFFFF" ClipToBounds="True">
                                                                <Grid>
                                                                    <Rectangle x:Name="ThumbnailImage" RadiusX="14" RadiusY="14">
                                                                        <Rectangle.Fill>
                                                                            <ImageBrush ImageSource="{Binding ThumbnailSource}" Stretch="UniformToFill" />
                                                                        </Rectangle.Fill>
                                                                        <Rectangle.Style>
                                                                            <Style TargetType="Rectangle">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding ThumbnailSource}" Value="{x:Null}">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Rectangle.Style>
                                                                    </Rectangle>
                                                                    <Border x:Name="FallbackBadge" Background="#14FFFFFF" Visibility="Collapsed"><Border.Style><Style TargetType="Border"><Style.Triggers><DataTrigger Binding="{Binding ThumbnailSource}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style><StackPanel VerticalAlignment="Center"><TextBlock HorizontalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding KindLabel}" /></StackPanel></Border>
                                                                </Grid>
                                                            </Border>
                                                            <TextBlock Grid.Row="1" Margin="4,8,4,0" HorizontalAlignment="Center" VerticalAlignment="Top" TextAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="24" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Text="{Binding DisplayName}" />
                                                        </Grid>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter TargetName="ShelfItemCard" Property="Background" Value="#11213A" />
                                                            <Setter TargetName="ShelfItemCard" Property="BorderBrush" Value="#7CB8FF" />
                                                            <Setter TargetName="ShelfItemCard" Property="BorderThickness" Value="1.4" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                        <Border x:Name="MusicView" Height="162" Padding="12,14,12,12" CornerRadius="20" Background="{StaticResource NotchBackgroundBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Visibility="Collapsed">
                            <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="132" /><ColumnDefinition Width="18" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Grid Width="132"
                                      Height="132"
                                      VerticalAlignment="Top">
                                    <Grid>
                                        <Rectangle x:Name="MusicArtworkShape"
                                                   RadiusX="28"
                                                   RadiusY="28"
                                                   Fill="{StaticResource NotchBackgroundBrush}" />
                                        <Grid x:Name="MusicArtworkFallback"><Viewbox Width="34" Height="34" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform"><Canvas Width="34" Height="34"><Path Fill="{StaticResource AccentBrush}" Data="M10,7 L26,12 L26,23.5 C26,27 23.3,30 19.8,30 C16.3,30 13.6,27.6 13.6,24.5 C13.6,21.3 16.2,19 19.8,19 C21.2,19 22.4,19.4 23.4,20.1 L23.4,14.1 L13.3,10.8 L13.3,24.2 C13.3,27.5 10.7,30 7.1,30 C3.7,30 1,27.6 1,24.5 C1,21.3 3.6,19 7.1,19 C8.4,19 9.7,19.4 10.6,20.1 z" /></Canvas></Viewbox></Grid>
                                    </Grid>
                                </Grid>
                                <Grid Grid.Column="2"
                                      MinHeight="136"
                                      VerticalAlignment="Top"
                                      Margin="0,0,0,0">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                    <TextBlock x:Name="MusicTitleText"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource SubtleBrush}"
                                               Text="Nothing playing"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                    <TextBlock x:Name="MusicArtistText"
                                               Grid.Row="1"
                                               Margin="0,4,0,0"
                                               FontSize="12.5"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="No media is playing right now."
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                    <Slider x:Name="MusicProgressSlider"
                                            Grid.Row="2"
                                            Height="16"
                                            Margin="0,12,0,0"
                                            Minimum="0"
                                            Maximum="1"
                                            Value="0"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource MusicProgressSliderStyle}" />
                                    <Grid Grid.Row="3"
                                          Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="MusicCurrentTimeText"
                                                   FontSize="11.5"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Text="0:00" />
                                        <TextBlock x:Name="MusicDurationText"
                                                   Grid.Column="1"
                                                   FontSize="11.5"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Text="0:00" />
                                    </Grid>
                                    <StackPanel Grid.Row="4"
                                                Margin="0,2,0,2"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                        <Button x:Name="PreviousTrackButton"
                                                Margin="0,0,12,0"
                                                Click="PreviousTrackButton_Click"
                                                Style="{StaticResource FlatMusicTransportButtonStyle}">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14"
                                                       Foreground="{StaticResource SubtleBrush}"
                                                       Text="&#xE892;" />
                                        </Button>
                                        <Button x:Name="PlayPauseButton"
                                                Margin="0,0,12,0"
                                                Click="PlayPauseButton_Click"
                                                Style="{StaticResource FlatMusicTransportButtonStyle}">
                                            <TextBlock x:Name="PlayPauseGlyph"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="20"
                                                       Foreground="{StaticResource SubtleBrush}"
                                                       Text="&#xE768;" />
                                        </Button>
                                        <Button x:Name="NextTrackButton"
                                                Click="NextTrackButton_Click"
                                                Style="{StaticResource FlatMusicTransportButtonStyle}">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14"
                                                       Foreground="{StaticResource SubtleBrush}"
                                                       Text="&#xE893;" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

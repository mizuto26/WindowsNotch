<Window x:Class="WindowsNotch.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowsNotch" Width="220" Height="52" WindowStartupLocation="Manual"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False" Topmost="False" AllowDrop="True"
        UseLayoutRounding="True" SnapsToDevicePixels="True" Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown" DragEnter="Window_DragEnter"
        DragOver="Window_DragOver" DragLeave="Window_DragLeave">
    <Grid Margin="6,0,6,10">
        <Border x:Name="NotchBody" Background="{StaticResource NotchBackgroundBrush}" BorderBrush="{StaticResource NotchBorderBrush}" BorderThickness="1,0,1,1" CornerRadius="0" RenderTransformOrigin="0.5,0" SizeChanged="NotchBody_SizeChanged">
            <Border.RenderTransform><ScaleTransform x:Name="NotchScaleTransform" ScaleX="1" ScaleY="1" /></Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="34" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <StackPanel x:Name="ModeSwitchPanel" Margin="26,4,0,0" HorizontalAlignment="Left" Orientation="Horizontal" Visibility="Collapsed">
                        <Button x:Name="MusicModeButton" Margin="0,0,14,0" Click="MusicModeButton_Click" Style="{StaticResource NotchTopIconButtonStyle}"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#F3F5F7" Text="&#xE189;" /></Button>
                        <Button x:Name="FilesModeButton" Click="FilesModeButton_Click" Style="{StaticResource NotchTopIconButtonStyle}"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#F3F5F7" Text="&#xE91B;" /></Button>
                    </StackPanel>
                    <Button x:Name="SettingsButton" Margin="0,4,26,0" HorizontalAlignment="Right" VerticalAlignment="Top" Visibility="Collapsed" Click="SettingsButton_Click" Style="{StaticResource NotchTopIconButtonStyle}"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#F3F5F7" Text="&#xE713;" /></Button>
                </Grid>
                <Grid Grid.Row="1" Margin="12,0,12,12">
                    <Border x:Name="ExpandedContentViewport" Margin="0,2,0,0" Height="0" Opacity="0" Background="Transparent" ClipToBounds="True">
                    <Grid x:Name="ExpandedContentRoot" RenderTransformOrigin="0.5,0">
                        <Grid.RenderTransform><TransformGroup><ScaleTransform x:Name="ExpandedContentScaleTransform" ScaleX="0.97" ScaleY="0.9" /><TranslateTransform x:Name="ExpandedContentTranslateTransform" Y="-6" /></TransformGroup></Grid.RenderTransform>
                        <Grid x:Name="FilesView" Height="170">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="198" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border x:Name="SharePanel" Grid.Column="0" Padding="10" CornerRadius="18" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" AllowDrop="True" DragEnter="SharePanel_DragEnter" DragOver="SharePanel_DragOver" DragLeave="SharePanel_DragLeave" Drop="SharePanel_Drop">
                                <Border x:Name="ShareDropZone" MinHeight="96" Padding="12" CornerRadius="16" Background="{StaticResource PanelInnerBrush}" BorderBrush="{StaticResource PanelInnerBorderBrush}" BorderThickness="1">
                                    <StackPanel VerticalAlignment="Center">
                                        <Viewbox Width="40" Height="40" HorizontalAlignment="Center" Stretch="Uniform"><Canvas Width="40" Height="40"><Path Fill="{StaticResource AccentBrush}" Data="M29.7,17.4 C28.7,12.7 24.5,9.2 19.5,9.2 C15.5,9.2 12,11.5 10.3,15 C5.8,15.4 2.3,19.2 2.3,23.8 C2.3,28.7 6.3,32.7 11.2,32.7 L29.2,32.7 C33.9,32.7 37.7,28.9 37.7,24.2 C37.7,19.7 34.2,16 29.7,15.7 z M29.2,29.6 L11.2,29.6 C8,29.6 5.4,27 5.4,23.8 C5.4,20.6 8,18 11.2,18 C11.5,18 11.8,18 12.1,18.1 L13.3,18.2 L13.8,17.1 C15.1,14.1 18.1,12.2 21.3,12.2 C25.3,12.2 28.7,15.2 29.2,19.1 L29.4,20.5 L30.7,20.4 C33.5,20.4 35.7,22.6 35.7,25.4 C35.7,27.8 33.6,29.6 29.2,29.6 z" /></Canvas></Viewbox>
                                        <TextBlock Margin="0,8,0,0" HorizontalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SubtleBrush}" Text="iCloud Drive" />
                                    </StackPanel>
                                </Border>
                            </Border>
                            <Border x:Name="ShelfPanel" Grid.Column="2" Padding="10" CornerRadius="18" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" AllowDrop="True" DragEnter="ShelfPanel_DragEnter" DragOver="ShelfPanel_DragOver" DragLeave="ShelfPanel_DragLeave" Drop="ShelfPanel_Drop">
                                <Grid Height="106" ClipToBounds="True">
                                    <Border x:Name="EmptyShelfPanel" Height="106" Padding="16" CornerRadius="16" Background="{StaticResource PanelInnerBrush}" BorderBrush="{StaticResource PanelInnerBorderBrush}" BorderThickness="1" VerticalAlignment="Top">
                                        <StackPanel VerticalAlignment="Center">
                                            <Viewbox Width="38" Height="38" HorizontalAlignment="Center" Stretch="Uniform"><Canvas Width="38" Height="38"><Path Stroke="{StaticResource AccentBrush}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M19 7 L19 22 M13 14 L19 8 L25 14" /><Path Stroke="{StaticResource AccentBrush}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M9 24 L9 28 C9 30.2 10.8 32 13 32 L25 32 C27.2 32 29 30.2 29 28 L29 24" /></Canvas></Viewbox>
                                            <TextBlock Margin="0,8,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SubtleBrush}" Text="Drop files here" />
                                        </StackPanel>
                                    </Border>
                                    <ListBox x:Name="ShelfList" Background="Transparent" BorderThickness="0" Height="106" VerticalAlignment="Top" Visibility="Collapsed" FocusVisualStyle="{x:Null}" SelectionChanged="ShelfList_SelectionChanged" PreviewKeyDown="ShelfList_PreviewKeyDown" ScrollViewer.HorizontalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="False" PreviewMouseLeftButtonDown="ShelfList_PreviewMouseLeftButtonDown" PreviewMouseMove="ShelfList_PreviewMouseMove">
                                        <ListBox.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="Padding" Value="0" /><Setter Property="Margin" Value="0,0,8,0" /><Setter Property="Background" Value="Transparent" /><Setter Property="BorderThickness" Value="0" /><Setter Property="HorizontalContentAlignment" Value="Stretch" /><Setter Property="VerticalContentAlignment" Value="Stretch" /><Setter Property="FocusVisualStyle" Value="{x:Null}" /><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><Border x:Name="ItemChrome" Padding="0" Background="Transparent" CornerRadius="12"><ContentPresenter /></Border><ControlTemplate.Triggers><Trigger Property="IsSelected" Value="True"><Setter TargetName="ItemChrome" Property="Background" Value="#14D1FF" /></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style></ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="110" Height="106" Padding="8" CornerRadius="14" Background="{StaticResource PanelInnerBrush}" BorderBrush="{StaticResource PanelInnerBorderBrush}" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.RowDefinitions><RowDefinition Height="62" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                                        <Border Grid.Row="0" CornerRadius="10" Background="#14FFFFFF" ClipToBounds="True">
                                                            <Grid>
                                                                <Image x:Name="ThumbnailImage" Stretch="UniformToFill" Source="{Binding ThumbnailSource}"><Image.Style><Style TargetType="Image"><Style.Triggers><DataTrigger Binding="{Binding ThumbnailSource}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger></Style.Triggers></Style></Image.Style></Image>
                                                                <Border x:Name="FallbackBadge" Background="#14FFFFFF" Visibility="Collapsed"><Border.Style><Style TargetType="Border"><Style.Triggers><DataTrigger Binding="{Binding ThumbnailSource}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style><StackPanel VerticalAlignment="Center"><TextBlock HorizontalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding KindLabel}" /></StackPanel></Border>
                                                            </Grid>
                                                        </Border>
                                                        <TextBlock Grid.Row="1" Margin="0,8,0,0" HorizontalAlignment="Center" VerticalAlignment="Top" TextAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="26" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource SubtleBrush}" Text="{Binding DisplayName}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>
                        <Border x:Name="MusicView" Height="158" Padding="12,14,12,12" CornerRadius="20" Background="{StaticResource NotchBackgroundBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Visibility="Collapsed">
                            <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="132" /><ColumnDefinition Width="18" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Grid Width="132"
                                      Height="132"
                                      VerticalAlignment="Top">
                                    <Grid>
                                        <Rectangle x:Name="MusicArtworkShape"
                                                   RadiusX="28"
                                                   RadiusY="28"
                                                   Fill="{StaticResource NotchBackgroundBrush}" />
                                        <Grid x:Name="MusicArtworkFallback"><Viewbox Width="34" Height="34" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform"><Canvas Width="34" Height="34"><Path Fill="{StaticResource AccentBrush}" Data="M10,7 L26,12 L26,23.5 C26,27 23.3,30 19.8,30 C16.3,30 13.6,27.6 13.6,24.5 C13.6,21.3 16.2,19 19.8,19 C21.2,19 22.4,19.4 23.4,20.1 L23.4,14.1 L13.3,10.8 L13.3,24.2 C13.3,27.5 10.7,30 7.1,30 C3.7,30 1,27.6 1,24.5 C1,21.3 3.6,19 7.1,19 C8.4,19 9.7,19.4 10.6,20.1 z" /></Canvas></Viewbox></Grid>
                                    </Grid>
                                </Grid>
                                <Grid Grid.Column="2"
                                      Height="132"
                                      VerticalAlignment="Top"
                                      Margin="0,0,0,0">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <TextBlock x:Name="MusicTitleText"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource SubtleBrush}"
                                               Text="Nothing playing"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                    <TextBlock x:Name="MusicArtistText"
                                               Grid.Row="1"
                                               Margin="0,4,0,0"
                                               FontSize="12.5"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="No media is playing right now."
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                    <Slider x:Name="MusicProgressSlider"
                                            Grid.Row="2"
                                            Height="16"
                                            Margin="0,12,0,0"
                                            Minimum="0"
                                            Maximum="1"
                                            Value="0"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource MusicProgressSliderStyle}" />
                                    <Grid Grid.Row="3"
                                          Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="MusicCurrentTimeText"
                                                   FontSize="11.5"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Text="0:00" />
                                        <TextBlock x:Name="MusicDurationText"
                                                   Grid.Column="1"
                                                   FontSize="11.5"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Text="0:00" />
                                    </Grid>
                                    <StackPanel Grid.Row="4"
                                                Margin="0,6,0,0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Bottom"
                                                Orientation="Horizontal">
                                        <Button x:Name="PreviousTrackButton"
                                                Margin="0,0,12,0"
                                                Click="PreviousTrackButton_Click"
                                                Style="{StaticResource FlatMusicTransportButtonStyle}">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14"
                                                       Foreground="{StaticResource SubtleBrush}"
                                                       Text="&#xE892;" />
                                        </Button>
                                        <Button x:Name="PlayPauseButton"
                                                Margin="0,0,12,0"
                                                Click="PlayPauseButton_Click"
                                                Style="{StaticResource FlatMusicTransportButtonStyle}">
                                            <TextBlock x:Name="PlayPauseGlyph"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="20"
                                                       Foreground="{StaticResource SubtleBrush}"
                                                       Text="&#xE768;" />
                                        </Button>
                                        <Button x:Name="NextTrackButton"
                                                Click="NextTrackButton_Click"
                                                Style="{StaticResource FlatMusicTransportButtonStyle}">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14"
                                                       Foreground="{StaticResource SubtleBrush}"
                                                       Text="&#xE893;" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                </Grid>
            </Grid>
        </Border>
        <Popup x:Name="DragPreviewPopup" AllowsTransparency="True" Focusable="False" IsHitTestVisible="False" Placement="AbsolutePoint" PopupAnimation="None" Opened="DragPreviewPopup_Opened" StaysOpen="True">
            <Border Padding="8" CornerRadius="14" Background="#F018181C" BorderBrush="#26FFFFFF" BorderThickness="1">
                <Border.Effect><DropShadowEffect BlurRadius="22" ShadowDepth="0" Color="#D0000000" Opacity="0.46" /></Border.Effect>
                <Grid Width="120">
                    <Grid.RowDefinitions><RowDefinition Height="74" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="10" Background="#18FFFFFF" ClipToBounds="True"><Grid><Image x:Name="DragPreviewImage" Stretch="UniformToFill" Visibility="Collapsed" /><Border x:Name="DragPreviewFallbackBadge" Background="#18FFFFFF" Visibility="Collapsed"><TextBlock x:Name="DragPreviewKindText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" /></Border></Grid></Border>
                    <TextBlock x:Name="DragPreviewNameText" Grid.Row="1" Margin="0,8,0,0" TextAlignment="Center" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="30" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SubtleBrush}" />
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Window>

<Window x:Class="WindowsNotch.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="420"
        MinHeight="304"
        ResizeMode="NoResize"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <Style x:Key="TrafficLightButtonStyle"
               TargetType="Button">
            <Setter Property="Width"
                    Value="12" />
            <Setter Property="Height"
                    Value="12" />
            <Setter Property="Margin"
                    Value="0,0,8,0" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedActionButtonStyle"
               TargetType="Button">
            <Setter Property="MinHeight"
                    Value="40" />
            <Setter Property="Padding"
                    Value="14,9" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Foreground"
                    Value="{StaticResource SubtleBrush}" />
            <Setter Property="Background"
                    Value="#14FFFFFF" />
            <Setter Property="BorderBrush"
                    Value="#1EFFFFFF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Chrome"
                                        Property="Opacity"
                                        Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Chrome"
                                        Property="Opacity"
                                        Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryRoundedActionButtonStyle"
               BasedOn="{StaticResource RoundedActionButtonStyle}"
               TargetType="Button">
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="Background"
                    Value="#FF3478F6" />
            <Setter Property="BorderBrush"
                    Value="#FF3478F6" />
        </Style>

        <Style x:Key="ToggleSwitchStyle"
               TargetType="CheckBox">
            <Setter Property="Focusable"
                    Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="46"
                              Height="28">
                            <Border x:Name="Track"
                                    CornerRadius="14"
                                    BorderThickness="1">
                                <Border.Background>
                                    <SolidColorBrush Color="#24FFFFFF" />
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#18FFFFFF" />
                                </Border.BorderBrush>
                            </Border>
                            <Border x:Name="Thumb"
                                    Width="22"
                                    Height="22"
                                    Margin="3,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="#FFF7F7F8"
                                    CornerRadius="11">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTranslateTransform" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslateTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="18"
                                                             Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="Track"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#FF3478F6"
                                                            Duration="0:0:0.16">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <ColorAnimation Storyboard.TargetName="Track"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#FF3478F6"
                                                            Duration="0:0:0.16">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslateTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="0"
                                                             Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="Track"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#24FFFFFF"
                                                            Duration="0:0:0.16">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <ColorAnimation Storyboard.TargetName="Track"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#18FFFFFF"
                                                            Duration="0:0:0.16">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="12"
            Padding="0"
            Background="{StaticResource NotchBackgroundBrush}"
            BorderBrush="{StaticResource NotchBorderBrush}"
            BorderThickness="1"
            CornerRadius="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30"
                              ShadowDepth="0"
                              Color="#B0000000"
                              Opacity="0.42" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="16,14,16,12"
                    BorderBrush="#14FFFFFF"
                    BorderThickness="0,0,0,1"
                    Background="#08FFFFFF">
                <Grid>
                    <Button HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource TrafficLightButtonStyle}"
                            Margin="0"
                            Background="#FFFE5F57"
                            Click="CloseChromeButton_Click" />

                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SubtleBrush}"
                               Text="WindowsNotch" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="16,16,16,0"
                    Padding="16"
                    CornerRadius="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SubtleBrush}"
                                   Text="Launch at startup" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="Open the notch automatically when Windows starts." />
                    </StackPanel>

                    <CheckBox x:Name="LaunchAtStartupCheckBox"
                              Grid.Column="1"
                              VerticalAlignment="Center"
                              Style="{StaticResource ToggleSwitchStyle}" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="16,12,16,0"
                    Padding="16"
                    CornerRadius="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SubtleBrush}"
                               Text="Sharing" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{StaticResource MutedBrush}"
                               Text="Open the iCloud folder used for instant sharing." />
                    <StackPanel Margin="0,14,0,0"
                                Orientation="Horizontal">
                        <Button HorizontalAlignment="Left"
                                Style="{StaticResource RoundedActionButtonStyle}"
                                Click="OpenShareGuideButton_Click"
                                Content="How to send to iPhone" />
                        <Button Margin="10,0,0,0"
                                HorizontalAlignment="Left"
                                Style="{StaticResource RoundedActionButtonStyle}"
                                Click="OpenICloudFolderButton_Click"
                                Content="Open iCloud share folder" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid Grid.Row="3"
                  Margin="16,16,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        MinWidth="90"
                        Margin="0,0,8,0"
                        Style="{StaticResource RoundedActionButtonStyle}"
                        Click="ExitButton_Click"
                        Content="Quit app" />

                <Button Grid.Column="2"
                        MinWidth="90"
                        Style="{StaticResource PrimaryRoundedActionButtonStyle}"
                        Click="SaveButton_Click"
                        Content="Save" />
            </Grid>
        </Grid>
    </Border>
</Window>

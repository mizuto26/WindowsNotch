<Window x:Class="WindowsNotch.App.ShareGuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="How to send to iPhone"
        Width="420"
        MinHeight="320"
        ResizeMode="NoResize"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <Style x:Key="RoundedActionButtonStyle"
               TargetType="Button">
            <Setter Property="MinHeight"
                    Value="40" />
            <Setter Property="MinWidth"
                    Value="92" />
            <Setter Property="Padding"
                    Value="16,9" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="Background"
                    Value="#FF3478F6" />
            <Setter Property="BorderBrush"
                    Value="#FF3478F6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Chrome"
                                        Property="Opacity"
                                        Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Chrome"
                                        Property="Opacity"
                                        Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="12"
            Background="{StaticResource NotchBackgroundBrush}"
            BorderBrush="{StaticResource NotchBorderBrush}"
            BorderThickness="1"
            CornerRadius="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30"
                              ShadowDepth="0"
                              Color="#B0000000"
                              Opacity="0.42" />
        </Border.Effect>

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="18,14,18,12"
                    BorderBrush="#14FFFFFF"
                    BorderThickness="0,0,0,1"
                    Background="#08FFFFFF">
                <Grid>
                    <Button Width="12"
                            Height="12"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="0"
                            Padding="0"
                            BorderThickness="0"
                            Background="#FFFE5F57"
                            Cursor="Hand"
                            Click="CloseButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" />
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SubtleBrush}"
                               Text="How to send to iPhone" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="1"
                        Margin="18,18,18,0">
                <TextBlock FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource SubtleBrush}"
                           Text="WindowsNotch uses iCloud Drive for sharing." />

                <TextBlock Margin="0,14,0,0"
                           FontSize="12"
                           Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap">
                    1. Install iCloud for Windows.
                </TextBlock>
                <TextBlock Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap">
                    2. Turn on iCloud Drive.
                </TextBlock>
                <TextBlock Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap">
                    3. Sign in on Windows and iPhone with the same Apple Account.
                </TextBlock>
                <TextBlock Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap">
                    4. Drag a file onto the AirDrop area in the notch.
                </TextBlock>
                <TextBlock Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap">
                    5. Open the Files app on iPhone.
                </TextBlock>
                <TextBlock Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap">
                    6. Go to iCloud Drive &gt; WindowsNotch to find the file.
                </TextBlock>

                <Border Margin="0,16,0,0"
                        Padding="12"
                        CornerRadius="14"
                        Background="{StaticResource PanelInnerBrush}"
                        BorderBrush="{StaticResource PanelInnerBorderBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="FolderPathTextBlock"
                               FontSize="11.5"
                               Foreground="{StaticResource SubtleBrush}"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <Grid Grid.Row="2"
                  Margin="18,18,18,18">
                <Button HorizontalAlignment="Right"
                        Style="{StaticResource RoundedActionButtonStyle}"
                        Click="OkButton_Click"
                        Content="OK" />
            </Grid>
        </Grid>
    </Border>
</Window>
